{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "smart-mcp",
  "model": "opencode/big-pickle",
  "temperature": 0.3,
  "mcp": {
    "smart": {
      "type": "local",
      "command": ["node", "__SMART_MCP_DIR__/src/server/index.mjs"],
      "enabled": true
    }
  },
  "agent": {
    "explorer": {
      "mode": "subagent",
      "description": "Fast explorer subagent for codebase exploration"
    }
  }
}
