{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 2
  },
  "include": [
    "src/**/*.mjs",
    "src/**/*.js",
    "src/**/*.cjs",
    "lib/**/*.mjs",
    "lib/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.mjs",
    "**/*.spec.mjs"
  ]
}
