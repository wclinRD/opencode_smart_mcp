# Personal Assistant Profile — 個人助理設定檔範本
# 複製此檔案到 ~/.config/personal-assistant/profile 並修改內容
# 執行: chmod 600 ~/.config/personal-assistant/profile 確保只有你可讀
#
# 格式: key=value
# 註解: # 開頭
# 多值: 逗號分隔，值內可含空白（如行事曆名稱）
# 編碼: UTF-8

# =============================================================================
# 基本設定
# =============================================================================

# 居住城市（用於天氣查詢）
# 有效值: Taipei, NewTaipei, Taoyuan, Taichung, Tainan, Kaohsiung, 等
city=Taipei

# =============================================================================
# 股市設定
# =============================================================================

# 台股關注清單（僅需股票代號，自動加上 .TW）
# 範例: 2330=台積電, 2454=聯發科, 2317=鴻海
stocks_tw=2330,2454,2317

# 美股關注清單（股票代號）
# 範例: AAPL=蘋果, TSLA=特斯拉, MSFT=微軟, NVDA=輝達
stocks_us=AAPL,TSLA,MSFT,NVDA

# =============================================================================
# 郵件帳號（給 mail-checker skill 使用）
# =============================================================================

# 要檢查的郵件帳號名稱（對應 Apple Mail 中的帳號顯示名稱）
# 範例: iCloud, Gmail, SMI, 公司信箱
accounts=iCloud,Gmail

# =============================================================================
# 行事曆設定
# =============================================================================

# 要讀取的行事曆名稱（對應 macOS Calendar.app 中的行事曆名稱）
# 留空則自動發現所有行事曆
# 注意: 名稱需完全符合（含空白與大小寫）
calendars=

# =============================================================================
# 新聞 RSS 來源設定
# =============================================================================

# 關注的新聞來源（逗號分隔）
# 可用來源:
#   ltn          自由時報（國內新聞）
#   cna          中央社（國內新聞）
#   bbc_world    BBC World（國際新聞）
#   bbc_business BBC Business（財經新聞）
#   technews     科技新報（科技新聞）
#   ithome       iThome（IT 新聞）
#   cnyes        鉅亨網（財經新聞）
news_feeds=ltn,cna,bbc_world,bbc_business,technews,ithome,cnyes

# 每個新聞來源最多取幾則
news_max_per_feed=5

# 新聞總量上限（超過則只取最新）
news_max_total=15

# =============================================================================
# Checkin 模式設定
# =============================================================================

# 每次 checkin 要執行的層級
# all = 全部 3 層
# 1,2 = 只跑第 1、2 層（快速模式，不含郵件/提醒/筆記/wiki）
# 可用值: all, 1, 2, 3 或組合如 1,2
checkin_layers=all

# =============================================================================
# Microsoft Teams 設定（選配）
# =============================================================================

# Teams 訊息回顧時間範圍（小時）
# 預設: 24（過去一天）
teams_msg_hours=24

# 最多載入多少個聊天室
# 預設: 10（避免過多請求）
teams_max_chats=10

# 每個聊天室最多取幾則訊息（依時間倒序，取最新）
# 預設: 20
teams_max_msg_per_chat=20

# 平行處理執行緒數（同時查多少聊天室）
# 預設: 5，可依網路狀況調整（1=全部循序，10=最大平行）
teams_max_workers=5

# Obsidian ms-outlook plugin token 路徑（選配）
# 留空則自動偵測常見位置
# 設定此值可強制使用特定路徑：
# teams_obsidian_token_path=

# =============================================================================
# 進階設定（選擇性）
# =============================================================================

# 日誌層級（DEBUG, INFO, WARN, ERROR）
log_level=INFO

# 逾時秒數（AppleScript 與網路呼叫）
timeout_seconds=10
