{
  "name": "smart-agent",
  "version": "0.1.0",
  "description": "Agent intelligence layer for opencode — tool strategies, workflow automation, memory integration, and planner orchestration on top of smart-mcp",
  "type": "module",
  "main": "src/index.mjs",
  "bin": {
    "smart-memory": "./src/cli/memory-store.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./system-prompt": "./src/agent/system-prompt.mjs",
    "./tool-strategy": "./src/agent/tool-strategy.mjs",
    "./workflow-strategy": "./src/agent/workflow-strategy.mjs",
    "./memory-integration": "./src/agent/memory-integration.mjs",
    "./planner-integration": "./src/agent/planner-integration.mjs"
  },
  "scripts": {
    "postinstall": "node src/install/postinstall.mjs",
    "test": "node --test \"tests/*.test.mjs\""
  },
  "peerDependencies": {
    "smart-mcp": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "smart-mcp": {
      "optional": true
    }
  },
  "keywords": [
    "opencode",
    "smart-mcp",
    "agent",
    "mcp",
    "ai",
    "coding-agent"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript-language-server": "^5.3.0"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@mozilla/readability": "0.6.0",
    "@playwright/mcp": "0.0.75",
    "better-sqlite3": "12.10.0",
    "crawlee": "3.17.0",
    "docx": "9.7.1",
    "file-type": "22.0.1",
    "html-to-text": "10.0.0",
    "impers": "0.0.7",
    "linkedom": "0.18.12",
    "mammoth": "1.12.0",
    "pdf-parse": "2.4.5",
    "sqlite-vec": "0.1.9",
    "turndown": "7.2.4",
    "xlsx": "0.18.5"
  }
}
